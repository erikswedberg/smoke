    { "year": 2021, "rankedDepth": 10, "honorableMentions": true,  "note": "Goldee's, a young Fort Worth upstart, dethrones the legends. First edition with honorable mentions." },
    { "year": 2025, "rankedDepth": 10, "honorableMentions": true,  "note": "Burnt Bean Co. takes #1. Snow's and Franklin both drop out of the top 10 for the first time ever." }
